---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const items = (await getCollection('bookshelf'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return items.map((item, i) => ({
    params: { slug: item.id },
    props: {
      item,
      prev: i > 0 ? { title: items[i - 1].data.title, href: `/bookshelf/${items[i - 1].id}` } : undefined,
      next: i < items.length - 1 ? { title: items[i + 1].data.title, href: `/bookshelf/${items[i + 1].id}` } : undefined,
    },
  }));
}

const { item, prev, next } = Astro.props;
const { Content, headings } = await render(item);
---

<PostLayout
  title={item.data.title}
  description={item.data.description}
  pubDate={item.data.pubDate}
  tags={item.data.tags}
  type={item.data.type}
  rating={item.data.rating}
  link={item.data.link}
  backHref="/bookshelf"
  backLabel="返回书架列表"
  headings={headings}
  prevPost={prev}
  nextPost={next}
>
  <Content />
</PostLayout>
