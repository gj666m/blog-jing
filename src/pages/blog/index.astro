---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 提取所有分类
const categories = [...new Set(allPosts.map((p) => p.data.category))];
---

<BaseLayout title="博文" description="技术学习与工作笔记">
  <div class="py-8 sm:py-12">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">博文</h1>

    <!-- 分类筛选 -->
    <div class="flex flex-wrap gap-2 mb-8">
      <a
        href="/blog"
        class="filter-btn text-sm px-4 py-1.5 rounded-full bg-gray-100 dark:bg-dark-surface text-gray-600 dark:text-gray-400 border border-transparent hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium"
      >
        全部
      </a>
      {categories.map((cat) => (
        <a
          href={`/blog?category=${cat}`}
          class="filter-btn text-sm px-4 py-1.5 rounded-full bg-gray-100 dark:bg-dark-surface text-gray-600 dark:text-gray-400 border border-transparent hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium"
          data-category={cat}
        >
          {cat}
        </a>
      ))}
    </div>

    <div class="grid gap-6 sm:grid-cols-2" id="blog-list">
      {allPosts.map((post) => (
        <div data-post-category={post.data.category}>
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            href={`/blog/${post.id}`}
            tags={post.data.tags}
            category={post.data.category}
          />
        </div>
      ))}
    </div>
    {allPosts.length === 0 && (
      <div class="text-center py-16">
        <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-dark-border mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
        <p class="text-gray-500 dark:text-gray-400">暂无博文</p>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  // URL 参数分类筛选
  const params = new URLSearchParams(window.location.search);
  const category = params.get('category');

  if (category) {
    // 高亮当前分类
    document.querySelectorAll('[data-category]').forEach((el) => {
      if (el.getAttribute('data-category') === category) {
        el.classList.add('bg-primary-600', 'text-white', 'border-primary-600');
        el.classList.remove('bg-gray-100', 'dark:bg-dark-surface', 'text-gray-600', 'dark:text-gray-400');
      }
    });

    // 过滤文章
    document.querySelectorAll('[data-post-category]').forEach((el) => {
      if (el.getAttribute('data-post-category') !== category) {
        (el as HTMLElement).style.display = 'none';
      }
    });
  }
</script>
