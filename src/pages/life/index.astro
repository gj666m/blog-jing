---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('life'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="生活" description="生活随笔、旅行记录与日常分享">
  <div class="py-8 sm:py-12">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-8">生活</h1>
    <div class="grid gap-6 sm:grid-cols-2">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          href={`/life/${post.id}`}
          tags={post.data.tags}
          type={post.data.type}
        />
      ))}
    </div>
    {posts.length === 0 && (
      <div class="text-center py-16">
        <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-dark-border mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
        <p class="text-gray-500 dark:text-gray-400">暂无内容</p>
      </div>
    )}
  </div>
</BaseLayout>
