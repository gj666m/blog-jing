---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  href: string;
  tags?: string[];
  category?: string;
  type?: string;
  coverImage?: string;
  rating?: number;
  link?: string;
}

const { title, description, pubDate, href, tags, category, type, coverImage, rating, link } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group">
  {coverImage && (
    <a href={href}>
      <img src={coverImage} alt={title} class="w-full h-40 object-cover rounded-t-[8px]" loading="lazy" decoding="async" />
    </a>
  )}
  <a href={href} class="block p-5 rounded-[8px] border border-gray-200 dark:border-dark-border hover:border-primary-600 dark:hover:border-primary-400 transition-all duration-300 hover:shadow-md hover:-translate-y-1">
    <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      {category && (
        <>
          <span class="text-gray-300 dark:text-dark-border">/</span>
          <span class="text-primary-600 dark:text-primary-400">{category}</span>
        </>
      )}
      {type && (
        <>
          <span class="text-gray-300 dark:text-dark-border">/</span>
          <span class="text-primary-600 dark:text-primary-400">{type}</span>
        </>
      )}
      {rating && (
        <>
          <span class="text-gray-300 dark:text-dark-border">/</span>
          <span>{'★'.repeat(rating)}{'☆'.repeat(5 - rating)}</span>
        </>
      )}
    </div>
    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors mb-2">
      {title}
    </h3>
    <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-2">{description}</p>
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-3">
        {tags.map((tag) => (
          <a href={`/tags/${tag}`} class="text-xs px-2 py-0.5 rounded-full bg-primary-50 text-primary-700 dark:bg-primary-900/20 dark:text-primary-300 hover:bg-primary-100 dark:hover:bg-primary-900/30 transition-colors">
            {tag}
          </a>
        ))}
      </div>
    )}
  </a>
  {link && (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 mt-2 ml-5 text-sm text-primary-600 dark:text-primary-400 hover:underline"
    >
      外部链接
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  )}
</article>
